# Squad: ignore runtime state (logs, inbox, sessions)
# Note: .squad/casting/* is identity and MUST be committed to main, not ignored
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
# ignore hve tracking files
.copilot-tracking/

# UberOS: local secrets and auth material (never commit)
config/nginx/.htpasswd
services/**/.env.local
*.local.env

# UberOS: frontend build artifacts and dependencies
services/frontend/node_modules/
services/frontend/dist/
services/frontend/.vite/

# UberOS: ROS workspace build outputs (regenerable; kept in named volumes)
workspace/build/
workspace/install/
workspace/log/
.env
build.log
