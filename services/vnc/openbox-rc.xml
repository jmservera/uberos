<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Openbox configuration for the UberOS display.
  Gazebo's Qt window is created without decorations and maximized so the
  simulator fills the virtual framebuffer and the noVNC panel shows the whole
  application instead of a small, unmanaged window on a black desktop.
-->
<openbox_config xmlns="http://openbox.org/3.4/rc">
  <applications>
    <application class="*">
      <decor>no</decor>
      <maximized>yes</maximized>
      <focus>yes</focus>
    </application>
  </applications>
</openbox_config>
