<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Fast DDS Discovery Server SUPER_CLIENT profile (ros service).

  Docker bridge networks do not reliably carry the multicast traffic that
  default DDS discovery relies on, which causes ROS nodes in separate
  containers to silently fail to find each other (research RISK-4).

  This profile points the ros container's participants at the central
  discovery-server so node/topic discovery works over unicast. It uses
  SUPER_CLIENT (not CLIENT) because this container runs the introspection
  surface — rosbridge, rosapi, and the ros2 CLI daemon — which must observe the
  ENTIRE ROS graph (every node, topic, and service), not just the endpoints it
  happens to match. A plain CLIENT only receives discovery data for endpoints
  that match its own readers/writers, so rosapi's services never propagated to
  rosbridge (`/rosapi/topics does not exist`) and the ROS Status panel's node
  query failed. A SUPER_CLIENT receives the full graph the server relays,
  restoring rosapi/rosbridge introspection (S3) while other containers stay
  lightweight CLIENTs.
-->
<dds xmlns="http://www.eprosima.com/XMLSchemas/fastRTPS_Profiles">
  <profiles>
    <participant profile_name="uberos_discovery_client" is_default_profile="true">
      <rtps>
        <builtin>
          <discovery_config>
            <discoveryProtocol>SUPER_CLIENT</discoveryProtocol>
            <discoveryServersList>
              <!-- Fast DDS 3.x (ROS Kilted): discoveryServersList children are
                   <locator> elements directly. The pre-3.x
                   <RemoteServer prefix="GUID"> form was removed and makes the
                   parser treat the list as empty ("without content"). -->
              <locator>
                <udpv4>
                  <address>discovery-server</address>
                  <port>11811</port>
                </udpv4>
              </locator>
            </discoveryServersList>
          </discovery_config>
        </builtin>
      </rtps>
    </participant>
  </profiles>
</dds>
