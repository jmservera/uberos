# Example basic-auth file for the reverse proxy.
#
# Authentication is OFF by default for localhost Init. Before any non-localhost
# exposure (NFR N-05), generate a real credentials file and enable auth_basic in
# services/proxy/nginx.conf:
#
#   htpasswd -c config/nginx/.htpasswd admin
#
# The real .htpasswd is git-ignored. This example is a placeholder only.
# admin / changeme  (DO NOT use in production)
admin:$apr1$examplex$0000000000000000000000
