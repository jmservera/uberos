# Force LF for shell scripts and container entrypoints. CRLF endings break the
# shebang inside Linux images (`env: bash\r: No such file or directory`).
*.sh text eol=lf
*.xml text eol=lf
*.conf text eol=lf
services/**/docker-entrypoint.d/* text eol=lf
# ROS/DDS config consumed inside Linux containers; keep LF.
services/ros/config/*.xml text eol=lf

# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
.squad/rai/audit-trail.md merge=union
.squad/fact-checker/audit-trail.md merge=union
